OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4-mini
LICENSE_SERVER_URL=http://license_api:8000
AI_AGENT_TOKEN=must-match-license-server-AI_AGENT_TOKEN
REDIS_URL=redis://ai_redis:6379
SESSION_TTL_SECONDS=86400
PUBLIC_BASE_URL=https://ai.yourdomain.com
LEAD_FOLLOWUP_WORKER_ENABLED=true
LEAD_FOLLOWUP_SCAN_INTERVAL_SECONDS=300
LEAD_FOLLOWUP_SCAN_BATCH_SIZE=500
LEAD_STALLED_AFTER_MINUTES=60
SALES_LEAD_PERSISTENCE_ENABLED=true
SALES_LEAD_REPOSITORY_BACKEND=redis
# Set SALES_LEAD_REPOSITORY_BACKEND=postgres to persist compact lead snapshots in Postgres.
# With docker compose, start the optional DB via: docker compose --profile postgres up -d
SALES_LEAD_POSTGRES_DSN=postgresql://ai_sales:ai_sales@ai_postgres:5432/ai_sales
SALES_LEAD_POSTGRES_DB=ai_sales
SALES_LEAD_POSTGRES_USER=ai_sales
SALES_LEAD_POSTGRES_PASSWORD=ai_sales
SALES_LEAD_RETENTION_DAYS=180
SALES_LEAD_TIMELINE_LIMIT=100
SALES_LEAD_MAX_PER_COMPANY=50000
SALES_CRM_SYNC_ENABLED=false
SALES_CRM_SYNC_WEBHOOK_URL=
SALES_CRM_SYNC_WORKER_ENABLED=true
SALES_CRM_SYNC_SCAN_INTERVAL_SECONDS=60
SALES_CRM_SYNC_BATCH_SIZE=100
SALES_CRM_SYNC_MAX_ATTEMPTS=8
SALES_CRM_SYNC_OUTBOX_RETENTION_DAYS=30
SALES_DASHBOARD_READ_TOKEN=
SALES_DASHBOARD_MANAGER_TOKEN=
SALES_DASHBOARD_ADMIN_TOKEN=
TELEGRAM_DEBUG_CATALOG_LIMIT=5
# Tenant-level ai_policy.lead_management can also set:
# proactive_followup_enabled, max_followups_per_lead, followup_cooldown_minutes,
# sales_owner_telegram_username, sales_owner_telegram_chat_id, telegram_bot_token,
# outbound_webhook_url. For private Telegram accounts, configure username and have the owner
# send /start to the tenant bot once, so the bot can resolve and store the numeric chat_id.
# followup_templates_by_status and followup_templates_by_next_action can override proactive
# follow-up messages per language/status/action.
# Any tenant can override runtime text without code changes through:
# ai_policy.i18n.translations.<lang>.<message_key>, for example
# i18n.translations.pt.catalog.sold_in = "Este produto é vendido em: {options}."
# SLA policy keys: hot_lead_owner_accept_sla_minutes, quote_prepare_sla_minutes,
# stalled_owner_escalation_minutes, sales_escalation_telegram_username,
# sales_escalation_telegram_chat_id.
# Sales dashboard API:
# GET /sales/leads?company_code=..., GET /sales/summary?company_code=...,
# GET /sales/managers/performance?company_code=...,
# GET /sales/funnel/source?company_code=..., GET /sales/dashboard/contract,
# GET /sales/admin/storage-summary, POST /sales/admin/prune,
# GET /sales/leads/{lead_id}/timeline, GET /sales/leads/{lead_id}/crm-export,
# POST /sales/leads/{lead_id}/quality/evaluate,
# POST /sales/leads/{lead_id}/merge,
# POST /sales/leads/{lead_id}/quote/sent|accepted|rejected,
# POST /sales/leads/{lead_id}/order-correction/requested|confirmed|applied|rejected
# require X-AI-Agent-Token.
# Dedupe policy keys: dedupe_enabled, dedupe_window_days, dedupe_scan_limit.
# Routing policy keys: sales_owner_routing.default_queue, hot_leads, languages.
# Sales policy keys: allow_discount_promises, allow_stock_promises_without_tool,
# allow_delivery_promises_without_tool, default_delivery_days, minimum_order_total,
# proactive_followup_channels.
